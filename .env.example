# ============================================================================
# Museic environment variables.
# Copy to .env at the repo root. The backend, scripts/, and muse_service/ all
# read this file. The Electron app reads app/.env (see app/.env.example).
# NEVER commit the filled-in .env.
# ============================================================================

# --- MongoDB -----------------------------------------------------------------
# From: MongoDB Atlas (https://cloud.mongodb.com) -> create free cluster ->
# Database Access (create user) -> Connect -> Drivers -> copy connection string.
# A local mongod also works: mongodb://localhost:27017
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_DB=museic

# --- Auth0 (identity + Token Vault) -------------------------------------------
# From: Auth0 dashboard (https://manage.auth0.com).
# Tenant domain: Applications -> <app> -> Settings -> Domain (e.g. dev-xyz.us.auth0.com).
AUTH0_DOMAIN=your-tenant.us.auth0.com

# Client ID of the NATIVE application (Applications -> Create Application ->
# Native). Add museic://callback to its Allowed Callback URLs. Public client,
# no secret needed for the PKCE login flow.
AUTH0_CLIENT_ID=

# Identifier ("audience") of the backend API you register in Auth0
# (Applications -> APIs -> Create API). The Electron app requests tokens for
# this audience; FastAPI validates them against it.
AUTH0_AUDIENCE=https://api.museic.local

# Custom API Client credentials for the Token Vault access-token exchange
# (Applications -> APIs -> <your backend API> -> Add Application; the created
# "Custom API Client" has the Token Vault grant enabled). Used ONLY by the
# backend to swap a user's Auth0 access token for a Spotify access token.
AUTH0_TOKEN_VAULT_CLIENT_ID=
AUTH0_TOKEN_VAULT_CLIENT_SECRET=

# Name of the Spotify connection you create in Auth0 (Authentication ->
# Social -> Create Connection -> Spotify, with "Connected Accounts for Token
# Vault" enabled). Usually just "spotify".
AUTH0_SPOTIFY_CONNECTION=spotify

# --- Backboard.io (Gemini orchestration) --------------------------------------
# From: https://app.backboard.io -> Settings -> API Keys.
BACKBOARD_API_KEY=
# Optional: pin narratives to one Backboard assistant so its persistent memory
# accumulates across sessions. Leave empty and the backend will create one on
# first use and log its id (then paste it here).
BACKBOARD_ASSISTANT_ID=
# Gemini model Backboard should route to for narrative generation.
BACKBOARD_GEMINI_MODEL=gemini-2.0-flash

# --- Gemini (direct, offline tagging only) ------------------------------------
# From: https://aistudio.google.com/apikey. Used ONLY by
# scripts/extract_features.py, because Backboard does not accept audio file
# uploads. All runtime narrative calls still go through Backboard.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Presage SmartSpectra ------------------------------------------------------
# From: https://physiology.presagetech.com (register -> API key). Consumed by
# the Electron app's Presage adapter (also mirrored in app/.env).
PRESAGE_API_KEY=

# --- Backend -------------------------------------------------------------------
# Where the FastAPI backend listens / where the app and muse service reach it.
BACKEND_URL=http://127.0.0.1:8000

# Folder containing your curated local audio library (mp3/wav/flac). Used by
# scripts/extract_features.py to read tracks and by the backend to stream audio
# to the app. Point this at your own music folder.
AUDIO_DIR=./library

# --- Muse companion service ------------------------------------------------------
# JWT for the user whose reactions the Muse readings belong to. Copy it from
# the Museic app: Profile menu -> "Copy API token" (tokens expire; re-copy for
# each session). The muse service must run natively on Windows/macOS, NOT WSL.
MUSE_USER_TOKEN=
# Song id currently playing is passed per-run; see muse_service/README notes.
